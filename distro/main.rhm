#lang rhombus/static
import:
  "catalog.rhm"
  "installer.rhm"
  "doc.rhm"
  "site.rhm"

fun build(version, config):
  catalog.build_catalog(version)
  installer.build_installer(version, config)
  doc.build_docs(version, config)
  site.build_site(version, config)

module main:
  import "cmdline.rhm"
  cmdline.parse(build)
